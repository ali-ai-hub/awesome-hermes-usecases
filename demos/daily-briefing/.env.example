# Daily Briefing demo — required and optional env vars.
# Copy to .env and fill in.

# --- required ---

# Firecrawl for web search. Get one at https://firecrawl.dev
FIRECRAWL_API_KEY=

# --- optional: Telegram delivery ---
# Leave blank to use local delivery (writes to ~/.hermes/cron/output/).
# Fill in to deliver to Telegram.

# Bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# Your numeric user ID from @userinfobot
TELEGRAM_ALLOWED_USERS=

# Optional channel/group ID for cron delivery. Leave blank to DM yourself.
TELEGRAM_HOME_CHANNEL=
