# Team Telegram demo — required env vars.
# Copy to .env and fill in.

# Bot token from @BotFather on Telegram.
TELEGRAM_BOT_TOKEN=

# Comma-separated list of allowed Telegram user IDs.
# Everyone listed gets full agent access — keep this tight.
# Get your ID from @userinfobot.
TELEGRAM_ALLOWED_USERS=

# Optional: a group/channel ID where cron jobs with --deliver telegram will post.
# Leave blank to skip setting a home channel.
TELEGRAM_HOME_CHANNEL=
